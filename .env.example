# cut-ai HTTP base (dev). Tauri webview uses this for transcribe / plan / recut.
VITE_CUT_AI_URL=http://127.0.0.1:8765

# Cmd‑K (`POST /v1/plan`) only: local | hybrid | cloud. Default when unset: hybrid
# (local Whisper; cloud/hybrid planner stub). Use `local` to exercise NL-planner-unavailable.
VITE_PLAN_DATA_RESIDENCY=hybrid
